rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // HELPER FUNCTIONS
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && getRole() == 'SUPER_ADMIN';
    }
    
    function isMedicalAdmin() {
      return isSignedIn() && (getRole() == 'MEDICAL_ADMIN' || getRole() == 'SUPER_ADMIN');
    }
    
    function isOps() {
      return isSignedIn() && (getRole() == 'OPS' || getRole() == 'SUPER_ADMIN');
    }

    // USERS COLLECTION
    match /users/{userId} {
      // Users can read/write their own profile
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      // Super Admins can manage all users
      allow read, update: if isSuperAdmin();
    }
    
    // BOOKINGS COLLECTION
    match /bookings/{bookingId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isOps() || isMedicalAdmin());
      // Ops and Super Admins can update status/payments
      allow update: if isSignedIn() && (
        (resource.data.userId == request.auth.uid && request.resource.data.status == resource.data.status) ||
        isOps()
      );
    }
    
    // RESULTS COLLECTION
    match /results/{resultId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isMedicalAdmin());
      // Only Medical Admins can create/edit results
      allow create, update: if isMedicalAdmin();
    }
    
    // AUDIT LOGS
    match /audit_logs/{logId} {
      allow create: if isOps() || isMedicalAdmin();
      allow read: if isSuperAdmin();
    }
    
    // TESTS (Read-only for all)
    match /tests/{testId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // LABS
    match /labs/{labId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
  }
}
