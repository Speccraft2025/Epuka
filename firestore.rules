rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // HELPER FUNCTIONS
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && getRole() == 'SUPER_ADMIN';
    }
    
    function isMedicalAdmin() {
      return isSignedIn() && (getRole() == 'MEDICAL_ADMIN' || getRole() == 'SUPER_ADMIN');
    }
    
    function isOps() {
      return isSignedIn() && (getRole() == 'OPS' || getRole() == 'SUPER_ADMIN');
    }

    // USERS COLLECTION
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin() || isOps() || isMedicalAdmin());
      allow write: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSuperAdmin();
    }
    
    // BOOKINGS COLLECTION
    match /bookings/{bookingId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isOps() || isMedicalAdmin());
      
      // Strict state updates
      allow update: if isSignedIn() && (
        isSuperAdmin() || 
        (isOps() && resource.data.status != 'CLOSED') ||
        (isMedicalAdmin() && resource.data.status != 'CLOSED')
      );
    }
    
    // RESULTS COLLECTION
    match /results/{resultId} {
      // Patients can only see APPROVED results
      allow read: if isSignedIn() && (
        (resource.data.userId == request.auth.uid && resource.data.medicalApprovalStatus == 'APPROVED') || 
        isMedicalAdmin()
      );
      
      // Only Medical Admins can create/edit results
      allow create, update: if isMedicalAdmin();
    }
    
    // AUDIT LOGS (Append-only)
    match /audit_logs/{logId} {
      allow create: if isSignedIn();
      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }
    
    // LABS & TESTS
    match /labs/{labId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    match /tests/{testId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
  }
}
